# =============================================================================
# Graphene Central WebSocket Server — Production Environment
# =============================================================================

# 1. Server Port 
WS_PORT=4000

# 2. Central WS Secret
# This MUST match the CENTRAL_WS_SECRET in your Azure and local backends.
CENTRAL_WS_SECRET=super-secret-central-key

# 3. Main Instance Domain (Fallback)
# Set this to your Azure backend domain (e.g., graphene-main.azurewebsites.net)
MAIN_INSTANCE_DOMAIN=localhost

# 4. Known Peer Addresses (Optional)
# Leave empty to let the server resolve keys automatically via the internet.
KNOWN_PEER_ADDRESSES=
